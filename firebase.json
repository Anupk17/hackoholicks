{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "server.js",
      ".env",
      "*.zip"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/interveux_landing_page/code.html"
      }
    ]
  },
  "functions": {
    "source": "functions"
  }
}
